import React, { useMemo, useState } from "react";
import {
  FiBell,
  FiActivity,
  FiHeart,
  FiAlertTriangle,
  FiCheckCircle,
  FiClock,
  FiPlus,
  FiPhoneCall,
  FiX,
  FiEdit2,
  FiTrash2,
  FiBarChart2
} from "react-icons/fi";
import "./index.css";

const initialReminders = [
  { id: 1, name: "Paracetamol", time: "08:00 AM", status: "Taken", note: "After breakfast" },
  { id: 2, name: "Vitamin D", time: "01:00 PM", status: "Due now", note: "After lunch" },
  { id: 3, name: "BP Tablet", time: "08:00 PM", status: "Upcoming", note: "Night dose" },
];

const tips = [
  "Drink water regularly through the day.",
  "Walk for at least 20 minutes.",
  "Track BP and sugar after meals.",
  "Keep emergency contacts updated.",
];

function statusClass(status) {
  if (status === "Taken") return "badge success";
  if (status === "Due now") return "badge warning";
  if (status === "Missed") return "badge danger";
  return "badge neutral";
}

export default function App() {
  const [activeTab, setActiveTab] = useState("Dashboard");
  const [showModal, setShowModal] = useState(false);
  const [showManage, setShowManage] = useState(false);
  const [editingId, setEditingId] = useState(null);

  const [reminders, setReminders] = useState(initialReminders);
  const [form, setForm] = useState({
    name: "",
    time: "",
    status: "Upcoming",
    note: "",
  });

  const stats = useMemo(() => {
    const taken = reminders.filter((r) => r.status === "Taken").length;
    const upcoming = reminders.filter((r) => r.status === "Upcoming").length;
    const alerts = reminders.filter((r) => r.status === "Due now" || r.status === "Missed").length;

    return [
      { title: "Today's Reminders", value: reminders.length, icon: <FiBell /> },
      { title: "Taken", value: taken, icon: <FiCheckCircle /> },
      { title: "Upcoming", value: upcoming, icon: <FiClock /> },
      { title: "Alerts", value: alerts, icon: <FiAlertTriangle /> },
    ];
  }, [reminders]);

  const resetForm = () => {
    setForm({
      name: "",
      time: "",
      status: "Upcoming",
      note: "",
    });
    setEditingId(null);
  };

  const openAddModal = () => {
    resetForm();
    setShowModal(true);
  };

  const openEditModal = (item) => {
    setForm({
      name: item.name,
      time: item.time,
      status: item.status,
      note: item.note || "",
    });
    setEditingId(item.id);
    setShowModal(true);
  };

  const handleSaveReminder = (e) => {
    e.preventDefault();

    if (!form.name.trim() || !form.time.trim()) {
      alert("Please enter medicine name and time.");
      return;
    }

    if (editingId) {
      setReminders((prev) =>
        prev.map((item) =>
          item.id === editingId
            ? {
                ...item,
                name: form.name.trim(),
                time: form.time.trim(),
                status: form.status,
                note: form.note.trim(),
              }
            : item
        )
      );
    } else {
      const newReminder = {
        id: Date.now(),
        name: form.name.trim(),
        time: form.time.trim(),
        status: form.status,
        note: form.note.trim(),
      };
      setReminders((prev) => [newReminder, ...prev]);
    }

    resetForm();
    setShowModal(false);
    setActiveTab("Reminders");
  };

  const markTaken = (id) => {
    setReminders((prev) =>
      prev.map((item) =>
        item.id === id ? { ...item, status: "Taken" } : item
      )
    );
  };

  const markMissed = (id) => {
    setReminders((prev) =>
      prev.map((item) =>
        item.id === id ? { ...item, status: "Missed" } : item
      )
    );
  };

  const removeReminder = (id) => {
    setReminders((prev) => prev.filter((item) => item.id !== id));
  };

  const handleSOS = () => {
    alert("SOS triggered. Contacting emergency support...");
  };

  return (
    <div className="app-shell">
      <aside className="sidebar">
        <div className="brand">
          <div className="brand-mark">
            <FiHeart />
          </div>
          <div>
            <h2>Health Tracker</h2>
            <p>Premium care dashboard</p>
          </div>
        </div>

        <nav className="nav-links">
          {["Dashboard", "Reminders", "Records", "SOS"].map((tab) => (
            <button
              key={tab}
              className={`nav-item ${activeTab === tab ? "active" : ""}`}
              onClick={() => setActiveTab(tab)}
            >
              {tab === "Dashboard" && <FiActivity />}
              {tab === "Reminders" && <FiBell />}
              {tab === "Records" && <FiBarChart2 />}
              {tab === "SOS" && <FiAlertTriangle />}
              {tab}
            </button>
          ))}
        </nav>
      </aside>

      <main className="main-content">
        <header className="topbar">
          <div>
            <p className="eyebrow">Good afternoon</p>
            <h1>Welcome back, Sandeep</h1>
            <p className="subtext">Track medicines, reminders, records, and emergency actions in one elegant dashboard.</p>
          </div>

          <div className="topbar-actions">
            <button className="btn btn-secondary" onClick={() => setActiveTab("Records")}>
              View history
            </button>
            <button className="btn btn-primary" onClick={openAddModal}>
              <FiPlus /> Add reminder
            </button>
          </div>
        </header>

        <section className="hero-banner card">
          <div>
            <p className="eyebrow">Daily overview</p>
            <h2>Stay ahead of your medication schedule.</h2>
            <p className="muted">Review due medicines, log completed doses, and keep your personal care flow organized.</p>
          </div>
          <div className="hero-banner-side">
            <span className="hero-chip">Smart reminders</span>
            <span className="hero-chip">Health records</span>
            <span className="hero-chip">Emergency ready</span>
          </div>
        </section>

        <section className="stats-grid">
          {stats.map((item) => (
            <article className="card stat-card" key={item.title}>
              <div className="stat-icon">{item.icon}</div>
              <div>
                <p className="muted">{item.title}</p>
                <h3>{item.value}</h3>
              </div>
            </article>
          ))}
        </section>

        {activeTab === "Dashboard" && (
          <section className="content-grid">
            <article className="card panel">
              <div className="panel-head">
                <div>
                  <p className="eyebrow">Medication</p>
                  <h2>Today's reminders</h2>
                </div>
                <button className="btn btn-ghost" onClick={() => setShowManage((prev) => !prev)}>
                  {showManage ? "Close manage" : "Manage"}
                </button>
              </div>

              <div className="reminder-list">
                {reminders.map((item) => (
                  <div className="reminder-item" key={item.id}>
                    <div>
                      <h3>{item.name}</h3>
                      <p className="muted">{item.time}</p>
                      {item.note ? <p className="reminder-note">{item.note}</p> : null}
                    </div>

                    <div className="reminder-actions">
                      <span className={statusClass(item.status)}>{item.status}</span>
                      {showManage && (
                        <div className="inline-actions">
                          <button className="mini-btn" onClick={() => markTaken(item.id)}>Taken</button>
                          <button className="mini-btn" onClick={() => markMissed(item.id)}>Missed</button>
                          <button className="mini-btn" onClick={() => openEditModal(item)}>
                            <FiEdit2 />
                          </button>
                          <button className="mini-btn danger-outline" onClick={() => removeReminder(item.id)}>
                            <FiTrash2 />
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </article>

            <article className="card panel">
              <div className="panel-head">
                <div>
                  <p className="eyebrow">Wellness</p>
                  <h2>Health tips</h2>
                </div>
              </div>

              <div className="tips-list">
                {tips.map((tip, index) => (
                  <div className="tip-item" key={index}>
                    <span className="tip-dot"></span>
                    <p>{tip}</p>
                  </div>
                ))}
              </div>
            </article>

            <article className="card panel quick-panel">
              <div className="panel-head">
                <div>
                  <p className="eyebrow">Quick access</p>
                  <h2>Care shortcuts</h2>
                </div>
              </div>

              <div className="quick-grid">
                <button className="quick-card" onClick={openAddModal}>
                  <FiPlus />
                  <span>Add medicine</span>
                </button>
                <button className="quick-card" onClick={() => setActiveTab("Records")}>
                  <FiBarChart2 />
                  <span>Open records</span>
                </button>
                <button className="quick-card" onClick={() => setActiveTab("SOS")}>
                  <FiPhoneCall />
                  <span>Emergency</span>
                </button>
              </div>
            </article>
          </section>
        )}

        {activeTab === "Reminders" && (
          <section className="card panel">
            <div className="panel-head">
              <div>
                <p className="eyebrow">Reminder center</p>
                <h2>Manage all reminders</h2>
              </div>
              <button className="btn btn-primary" onClick={openAddModal}>
                <FiPlus /> New reminder
              </button>
            </div>

            <div className="reminder-list">
              {reminders.map((item) => (
                <div className="reminder-item" key={item.id}>
                  <div>
                    <h3>{item.name}</h3>
                    <p className="muted">{item.time}</p>
                    {item.note ? <p className="reminder-note">{item.note}</p> : null}
                  </div>

                  <div className="reminder-actions">
                    <span className={statusClass(item.status)}>{item.status}</span>
                    <div className="inline-actions">
                      <button className="mini-btn" onClick={() => markTaken(item.id)}>Taken</button>
                      <button className="mini-btn" onClick={() => markMissed(item.id)}>Missed</button>
                      <button className="mini-btn" onClick={() => openEditModal(item)}>
                        <FiEdit2 />
                      </button>
                      <button className="mini-btn danger-outline" onClick={() => removeReminder(item.id)}>
                        <FiTrash2 />
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        {activeTab === "Records" && (
          <section className="card panel">
            <div className="panel-head">
              <div>
                <p className="eyebrow">Records</p>
                <h2>Reminder history</h2>
              </div>
            </div>

            <div className="tips-list">
              {reminders.map((item) => (
                <div className="tip-item" key={item.id}>
                  <span className="tip-dot"></span>
                  <p>{item.name} - {item.time} - {item.status}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {activeTab === "SOS" && (
          <section className="card panel sos-panel">
            <div className="panel-head">
              <div>
                <p className="eyebrow danger-text">Emergency</p>
                <h2>SOS support</h2>
              </div>
            </div>

            <p className="muted">
              Use this panel for emergency assistance, caregiver contact workflows, and rapid response actions.
            </p>

            <div className="quick-grid">
              <button className="quick-card" onClick={handleSOS}>
                <FiPhoneCall />
                <span>Trigger SOS</span>
              </button>
              <button className="quick-card" onClick={() => alert("Emergency contact flow can be connected here.")}>
                <FiHeart />
                <span>Care contact</span>
              </button>
              <button className="quick-card" onClick={() => alert("Ambulance support flow can be connected here.")}>
                <FiAlertTriangle />
                <span>Urgent help</span>
              </button>
            </div>
          </section>
        )}
      </main>

      {showModal && (
        <div className="modal-backdrop" onClick={() => setShowModal(false)}>
          <div className="modal-card" onClick={(e) => e.stopPropagation()}>
            <div className="modal-head">
              <div>
                <p className="eyebrow">{editingId ? "Edit entry" : "New entry"}</p>
                <h2>{editingId ? "Edit reminder" : "Add reminder"}</h2>
              </div>
              <button className="icon-btn" onClick={() => setShowModal(false)}>
                <FiX />
              </button>
            </div>

            <form className="modal-form" onSubmit={handleSaveReminder}>
              <label>
                Medicine name
                <input
                  type="text"
                  value={form.name}
                  onChange={(e) => setForm({ ...form, name: e.target.value })}
                  placeholder="Enter medicine name"
                />
              </label>

              <label>
                Time
                <input
                  type="text"
                  value={form.time}
                  onChange={(e) => setForm({ ...form, time: e.target.value })}
                  placeholder="Eg: 09:30 PM"
                />
              </label>

              <label>
                Status
                <select
                  value={form.status}
                  onChange={(e) => setForm({ ...form, status: e.target.value })}
                >
                  <option>Upcoming</option>
                  <option>Due now</option>
                  <option>Taken</option>
                  <option>Missed</option>
                </select>
              </label>

              <label>
                Note
                <input
                  type="text"
                  value={form.note}
                  onChange={(e) => setForm({ ...form, note: e.target.value })}
                  placeholder="Optional note"
                />
              </label>

              <div className="modal-actions">
                <button type="button" className="btn btn-secondary" onClick={() => setShowModal(false)}>
                  Cancel
                </button>
                <button type="submit" className="btn btn-primary">
                  {editingId ? "Update reminder" : "Save reminder"}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}
